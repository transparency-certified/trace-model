
# Install trace-model's own package from the source tree COPY'd into the image.
# Provides the tro_fingerprint_state and merge_states console scripts the demos
# invoke. (trace-model is a "final" repro -- not required by other repros -- so
# it always installs from its own source; no source-vs-published switch needed.)
sudo pip install /repro

